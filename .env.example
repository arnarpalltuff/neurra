# Copy to .env and fill in real values. .env is gitignored; .env.example is committed.

# Supabase project URL — find at: Dashboard → Settings → API → Project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable key — find at: Dashboard → Settings → API → Project API keys (publishable / anon)
# Safe to ship in the app bundle; this is NOT the service_role key.
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_replace_me
